{
  "name": "DiagnosticSession",
  "type": "object",
  "properties": {
    "session_date": {
      "type": "string",
      "format": "date-time"
    },
    "vehicle": {
      "type": "string",
      "description": "Vehicle identifier"
    },
    "vin": {
      "type": "string"
    },
    "protocol": {
      "type": "string",
      "enum": [
        "ISO15765-4_CAN_11bit_500K",
        "ISO15765-4_CAN_29bit_500K",
        "ISO14230-4_KWP",
        "AUTO"
      ]
    },
    "baudrate": {
      "type": "number"
    },
    "modules_scanned": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "dtcs_found": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "module": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "critical",
              "high",
              "medium",
              "low"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "pending",
              "cleared"
            ]
          }
        }
      }
    },
    "live_data_snapshots": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "string"
          },
          "battery_12v": {
            "type": "number"
          },
          "battery_48v_voltage": {
            "type": "number"
          },
          "battery_48v_soc": {
            "type": "number"
          },
          "battery_48v_current": {
            "type": "number"
          },
          "ifs_left_angle": {
            "type": "number"
          },
          "ifs_right_angle": {
            "type": "number"
          },
          "vehicle_speed": {
            "type": "number"
          }
        }
      }
    },
    "cleared_codes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "technician_notes": {
      "type": "string"
    },
    "report_generated": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "vehicle",
    "protocol"
  ]
}